# Off the Hook — Storefront Environment Variables
# Copy to .env.local for development, set in Vercel for production
#
# TEMPLATE FOR A NEW TENANT: this codebase is written to be tenant-agnostic — the ONE variable
# that makes it a different store is NEXT_PUBLIC_VULA_TENANT_ID below. Set it, set the rest of
# this file for the new tenant's own accounts, deploy to a new Vercel project. See TEMPLATE.md.

# Which Vula tenant this storefront renders — THE variable to change for a new tenant.
# Falls back to "off-the-hook" everywhere it's read if left blank, so this must be set.
NEXT_PUBLIC_VULA_TENANT_ID=off-the-hook

# Vula backend (Railway)
NEXT_PUBLIC_VULA_API_URL=https://api.vula.co.za
VULA_API_KEY=

# Yoco (public key for client-side SDK if needed)
NEXT_PUBLIC_YOCO_PUBLIC_KEY=pk_live_xxxx

# Site
NEXT_PUBLIC_SITE_URL=https://offthehook.co.za
NEXT_PUBLIC_WHATSAPP_NUMBER=27791783933

# Admin — required for /admin login (set in Vercel for production)
ADMIN_PASSWORD=choose-a-strong-password

# Supabase — product image storage (recommended for production uploads)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Google Drive — bulk image import in /admin/import
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional; defaults to {site}/admin/api/google/callback
GOOGLE_REDIRECT_URI=
